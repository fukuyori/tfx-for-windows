<UserControl x:Class="Tfx.PathBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="CrumbButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TfxForeground}" />
            <Setter Property="FontFamily" Value="Consolas, Yu Gothic UI" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#202830" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="#0D1013" BorderBrush="{DynamicResource TfxBorder}" BorderThickness="1" MinHeight="28">
        <Grid>
            <DockPanel x:Name="CrumbHost" LastChildFill="True">
                <StackPanel x:Name="CrumbPanel" Orientation="Horizontal" DockPanel.Dock="Left" />
                <Border x:Name="ClickCatcher" Background="Transparent" Cursor="IBeam" MouseLeftButtonDown="ClickCatcher_MouseDown" />
            </DockPanel>
            <TextBox x:Name="EditBox"
                     Visibility="Collapsed"
                     Background="#0D1013"
                     Foreground="{DynamicResource TfxForeground}"
                     CaretBrush="{DynamicResource TfxAccent}"
                     BorderThickness="0"
                     Padding="6,0"
                     VerticalContentAlignment="Center"
                     FontFamily="Consolas, Yu Gothic UI"
                     KeyDown="EditBox_KeyDown"
                     LostKeyboardFocus="EditBox_LostKeyboardFocus" />
        </Grid>
    </Border>
</UserControl>
