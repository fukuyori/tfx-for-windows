<Window x:Class="Tfx.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tfx"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="tfx"
        Icon="/Assets/AppIcon.ico"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        MinHeight="560"
        MinWidth="980"
        Height="760"
        Width="1280"
        Background="{DynamicResource TfxBackground}"
        Foreground="{DynamicResource TfxForeground}"
        FontFamily="Consolas, Yu Gothic UI"
        KeyDown="Window_KeyDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="ListingCellText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="RightAlignedCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="CenteredCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource TfxHitSurface}" BorderBrush="{DynamicResource TfxBorder}" BorderThickness="0,0,0,1" Padding="5,4" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BackButton" Style="{StaticResource ToolbarButton}" Click="Back_Click" ToolTip="Back (Alt+Left)" Content="&#xE72B;" />
                    <Button x:Name="ForwardButton" Style="{StaticResource ToolbarButton}" Click="Forward_Click" ToolTip="Forward (Alt+Right)" Content="&#xE72A;" />
                    <Button x:Name="ParentButton" Style="{StaticResource ToolbarButton}" Click="Parent_Click" ToolTip="Up (Alt+Up / Backspace)" Content="&#xE74A;" />
                    <Button x:Name="TogglePinButton" Style="{StaticResource ToolbarButton}" Click="TogglePin_Click" ToolTip="Pin / unpin current folder" Content="&#xE718;" />
                </StackPanel>
                <Grid Grid.Column="1" Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource TfxHitSurface}" MinHeight="22" Margin="0,0,8,0" />
                    <TextBox x:Name="SearchBox" Grid.Column="1" VerticalContentAlignment="Center" KeyDown="SearchBox_KeyDown" PreviewKeyDown="SearchBox_PreviewKeyDown" />
                    <Button x:Name="FocusSearchButton" Grid.Column="2" Style="{StaticResource ToolbarButton}" Click="FocusSearch_Click" ToolTip="Focus search (Ctrl+F)" Content="&#xE721;" />
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="ViewModeButton" Style="{StaticResource ToolbarButton}" Click="ViewMode_Click" ToolTip="Switch view mode" Content="&#xE8A9;" />
                    <ToggleButton x:Name="HiddenButton" Style="{StaticResource ToolbarToggleButton}" Click="Hidden_Click" ToolTip="Toggle hidden files (Ctrl+Shift+.)" Content="&#xE890;" />
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button x:Name="TerminalButton" Style="{StaticResource ToolbarButton}" Click="Terminal_Click" ToolTip="Open Terminal here (Ctrl+Shift+T)" Content="&#xE756;" />
                    <Button x:Name="ReloadButton" Style="{StaticResource ToolbarButton}" Click="Reload_Click" ToolTip="Reload (Ctrl+R)" Content="&#xE72C;" />
                    <ToggleButton x:Name="PreviewButton" Style="{StaticResource ToolbarToggleButton}" Click="Preview_Click" ToolTip="Toggle preview">
                        <Viewbox Width="15" Height="11" Stretch="Uniform">
                            <Grid Width="15" Height="11">
                                <Rectangle Width="14"
                                           Height="10"
                                           RadiusX="1.8"
                                           RadiusY="1.8"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                           StrokeThickness="1.4"
                                           Fill="Transparent"
                                           SnapsToDevicePixels="True" />
                                <Line X1="10"
                                      Y1="1.7"
                                      X2="10"
                                      Y2="9.3"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="1.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      SnapsToDevicePixels="True" />
                            </Grid>
                        </Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="SplitButton" Style="{StaticResource ToolbarToggleButton}" Click="Split_Click" ToolTip="Toggle split pane">
                        <Viewbox Width="15" Height="11" Stretch="Uniform">
                            <Grid Width="15" Height="11">
                                <Rectangle Width="14"
                                           Height="10"
                                           RadiusX="1.8"
                                           RadiusY="1.8"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                           StrokeThickness="1.4"
                                           Fill="Transparent"
                                           SnapsToDevicePixels="True" />
                                <Line X1="7.5"
                                      Y1="1.7"
                                      X2="7.5"
                                      Y2="9.3"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="1.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      SnapsToDevicePixels="True" />
                            </Grid>
                        </Viewbox>
                    </ToggleButton>
                    <Button x:Name="SwapPanesButton" Style="{StaticResource ToolbarButton}" Click="SwapPanes_Click" ToolTip="Swap left and right panes (Ctrl+Shift+X)">
                        <Viewbox Width="15" Height="11" Stretch="Uniform">
                            <Grid Width="15" Height="11">
                                <Rectangle Width="5"
                                           Height="9"
                                           RadiusX="1.2"
                                           RadiusY="1.2"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1.2"
                                           Fill="Transparent"
                                           SnapsToDevicePixels="True" />
                                <Rectangle Width="5"
                                           Height="9"
                                           RadiusX="1.2"
                                           RadiusY="1.2"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1.2"
                                           Fill="Transparent"
                                           SnapsToDevicePixels="True" />
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M 5.5,3.5 L 9.5,3.5 M 8.5,2.5 L 9.5,3.5 L 8.5,4.5 M 5.5,7.5 L 9.5,7.5 M 6.5,6.5 L 5.5,7.5 L 6.5,8.5"
                                      SnapsToDevicePixels="True" />
                            </Grid>
                        </Viewbox>
                    </Button>
                    <ToggleButton x:Name="TerminalPaneButton" Style="{StaticResource ToolbarToggleButton}" Click="TerminalPane_Click" Content="&#xE756;" />
                    <Button Style="{StaticResource ToolbarButton}" x:Name="ColumnsButton" Click="Columns_Click" ToolTip="Columns" Content="&#xE713;" />
                </StackPanel>
                <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button x:Name="MinimizeButton" Style="{StaticResource ToolbarButton}" Click="Minimize_Click" Content="&#xE921;" />
                    <Button x:Name="MaximizeRestoreButton" Style="{StaticResource ToolbarButton}" Click="MaximizeRestore_Click" Content="&#xE922;" />
                    <Button x:Name="CloseButton" Style="{StaticResource ToolbarButton}" Click="Close_Click" Content="&#xE8BB;" />
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource TfxChrome}" Foreground="{DynamicResource TfxMuted}" BorderBrush="{DynamicResource TfxBorder}" BorderThickness="0,1,0,0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel HorizontalAlignment="Stretch" LastChildFill="False" />
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem DockPanel.Dock="Left">
                <TextBlock x:Name="StatusText" />
            </StatusBarItem>
            <StatusBarItem DockPanel.Dock="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="GitBranchText" Margin="0,0,12,0" />
                    <TextBlock x:Name="FreeSpaceText" Margin="0,0,12,0" />
                    <TextBlock x:Name="VersionStatusText" Margin="0,0,8,0" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120" />
                <RowDefinition x:Name="TerminalSplitterRow" Height="Auto" />
                <RowDefinition x:Name="TerminalRow" Height="0" MinHeight="0" />
            </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="180" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition x:Name="PreviewSplitterColumn" Width="5" />
                <ColumnDefinition x:Name="PreviewColumn" Width="320" MinWidth="240" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource TfxPanel}" BorderBrush="{DynamicResource TfxBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock x:Name="PinnedHeader" DockPanel.Dock="Top" Text="PINNED" Foreground="{DynamicResource TfxMuted}" Margin="10,10,10,4" />
                    <ListBox x:Name="PinnedList" DockPanel.Dock="Top" Padding="4,0,4,12" Background="{DynamicResource TfxPanel}" Foreground="{DynamicResource TfxForeground}" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="PinnedList_SelectionChanged" PreviewMouseMove="PinnedList_PreviewMouseMove" PreviewMouseRightButtonDown="PinnedList_PreviewMouseRightButtonDown" ContextMenuOpening="PinnedList_ContextMenuOpening" DragOver="PinnedList_DragOver" Drop="PinnedList_Drop" AllowDrop="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Foreground" Value="{DynamicResource TfxForeground}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4"
                                                    Padding="6,4"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Stretch" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TfxHover}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TfxSelection}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TfxSelectionForeground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <local:MiddleEllipsisTextBlock FullText="{Binding}"
                                                               ToolTip="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="FoldersHeader" DockPanel.Dock="Top" Text="FOLDERS" Foreground="{DynamicResource TfxMuted}" Margin="10,4,10,4" />
                    <TreeView x:Name="FolderTree" Background="{DynamicResource TfxPanel}" Foreground="{DynamicResource TfxForeground}" BorderThickness="0" SelectedItemChanged="FolderTree_SelectedItemChanged" PreviewMouseLeftButtonUp="FolderTree_PreviewMouseLeftButtonUp" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="{DynamicResource TfxBorder}" HorizontalAlignment="Stretch" />

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftPaneColumn" Width="*" />
                    <ColumnDefinition x:Name="PaneSplitterColumn" Width="5" />
                    <ColumnDefinition x:Name="RightPaneColumn" Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="LeftPaneBorder" Grid.Column="0" Background="{DynamicResource TfxPanelActive}" BorderBrush="{DynamicResource TfxBorder}" BorderThickness="1" Margin="8">
                    <DockPanel>
                        <ItemsControl x:Name="LeftTabStrip" DockPanel.Dock="Top" Margin="6,4,6,0" Visibility="Collapsed">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <local:PathBar x:Name="LeftPathBar" DockPanel.Dock="Top" Margin="6,6,6,4" PathRequested="LeftPathBar_PathRequested" />
                        <Grid>
                        <DataGrid x:Name="LeftGrid" ItemsSource="{Binding LeftItems}" IsReadOnly="True" MouseDoubleClick="Grid_MouseDoubleClick" SelectionChanged="Grid_SelectionChanged" GotFocus="Grid_GotFocus" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver" PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Listing_PreviewMouseLeftButtonUp" PreviewMouseMove="Grid_PreviewMouseMove" PreviewMouseRightButtonDown="Grid_PreviewMouseRightButtonDown" ContextMenuOpening="Grid_ContextMenuOpening" CellEditEnding="Grid_CellEditEnding" Sorting="Grid_Sorting" CanUserResizeColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn x:Name="LeftNameColumn" Header="Name" Width="280" MinWidth="200" SortMemberPath="Name" CanUserResize="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" SnapsToDevicePixels="True" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Name, Mode=OneWay}" VerticalAlignment="Center" Padding="6,2" FontFamily="Consolas, Yu Gothic UI" Loaded="RenameTextBox_Loaded" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="LeftGitColumn" Header="Git" Binding="{Binding GitStatusText}" SortMemberPath="GitStatusText" Width="30" ElementStyle="{StaticResource CenteredCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftDateModifiedColumn" Header="Date modified" Binding="{Binding ModifiedText}" SortMemberPath="Modified" Width="155" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftTypeColumn" Header="Type" Binding="{Binding Kind}" SortMemberPath="Kind" Width="110" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftSizeColumn" Header="Size" Binding="{Binding SizeText}" SortMemberPath="Size" Width="95" ElementStyle="{StaticResource RightAlignedCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftDateCreatedColumn" Header="Date created" Binding="{Binding CreatedText}" SortMemberPath="Created" Width="155" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftOwnerColumn" Header="Owner" Binding="{Binding OwnerText}" SortMemberPath="OwnerText" Width="160" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftAttributeColumn" Header="Attribute" Binding="{Binding AttributeText}" SortMemberPath="AttributeText" Width="90" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <ListBox x:Name="LeftIconView" Visibility="Collapsed" ItemsSource="{Binding LeftItems}"
                                 Background="{DynamicResource TfxPanel}" BorderThickness="0" SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="IconView_SelectionChanged" MouseDoubleClick="IconView_MouseDoubleClick"
                                 GotFocus="IconView_GotFocus" PreviewMouseLeftButtonDown="IconView_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Listing_PreviewMouseLeftButtonUp" PreviewMouseRightButtonDown="IconView_PreviewMouseRightButtonDown"
                                 ContextMenuOpening="IconView_ContextMenuOpening" PreviewMouseMove="IconView_PreviewMouseMove"
                                 AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Foreground" Value="{DynamicResource TfxForeground}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource TfxSelection}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TfxSelectionForeground}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="108" Margin="6,7">
                                        <Image Source="{Binding LargeIcon}" Width="32" Height="32" HorizontalAlignment="Center" Stretch="None" SnapsToDevicePixels="True" />
                                        <TextBlock Text="{Binding Name}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Canvas x:Name="LeftSelectionOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                            <Border x:Name="LeftSelectionRect" BorderBrush="{DynamicResource TfxAccent}" BorderThickness="1" Background="{DynamicResource TfxSelectionOverlay}" />
                        </Canvas>
                        </Grid>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" Background="{DynamicResource TfxBorder}" HorizontalAlignment="Stretch" />

                <Border x:Name="RightPaneBorder" Grid.Column="2" Background="{DynamicResource TfxPanel}" BorderBrush="{DynamicResource TfxBorder}" BorderThickness="1" Margin="8">
                    <DockPanel>
                        <ItemsControl x:Name="RightTabStrip" DockPanel.Dock="Top" Margin="6,4,6,0" Visibility="Collapsed">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <local:PathBar x:Name="RightPathBar" DockPanel.Dock="Top" Margin="6,6,6,4" PathRequested="RightPathBar_PathRequested" />
                        <Grid>
                        <DataGrid x:Name="RightGrid" ItemsSource="{Binding RightItems}" IsReadOnly="True" MouseDoubleClick="Grid_MouseDoubleClick" SelectionChanged="Grid_SelectionChanged" GotFocus="Grid_GotFocus" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver" PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Listing_PreviewMouseLeftButtonUp" PreviewMouseMove="Grid_PreviewMouseMove" PreviewMouseRightButtonDown="Grid_PreviewMouseRightButtonDown" ContextMenuOpening="Grid_ContextMenuOpening" CellEditEnding="Grid_CellEditEnding" Sorting="Grid_Sorting" CanUserResizeColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn x:Name="RightNameColumn" Header="Name" Width="280" MinWidth="200" SortMemberPath="Name" CanUserResize="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" SnapsToDevicePixels="True" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Name, Mode=OneWay}" VerticalAlignment="Center" Padding="6,2" FontFamily="Consolas, Yu Gothic UI" Loaded="RenameTextBox_Loaded" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="RightGitColumn" Header="Git" Binding="{Binding GitStatusText}" SortMemberPath="GitStatusText" Width="30" ElementStyle="{StaticResource CenteredCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightDateModifiedColumn" Header="Date modified" Binding="{Binding ModifiedText}" SortMemberPath="Modified" Width="155" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightTypeColumn" Header="Type" Binding="{Binding Kind}" SortMemberPath="Kind" Width="110" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightSizeColumn" Header="Size" Binding="{Binding SizeText}" SortMemberPath="Size" Width="95" ElementStyle="{StaticResource RightAlignedCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightDateCreatedColumn" Header="Date created" Binding="{Binding CreatedText}" SortMemberPath="Created" Width="155" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightOwnerColumn" Header="Owner" Binding="{Binding OwnerText}" SortMemberPath="OwnerText" Width="160" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightAttributeColumn" Header="Attribute" Binding="{Binding AttributeText}" SortMemberPath="AttributeText" Width="90" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <ListBox x:Name="RightIconView" Visibility="Collapsed" ItemsSource="{Binding RightItems}"
                                 Background="{DynamicResource TfxPanel}" BorderThickness="0" SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="IconView_SelectionChanged" MouseDoubleClick="IconView_MouseDoubleClick"
                                 GotFocus="IconView_GotFocus" PreviewMouseLeftButtonDown="IconView_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Listing_PreviewMouseLeftButtonUp" PreviewMouseRightButtonDown="IconView_PreviewMouseRightButtonDown"
                                 ContextMenuOpening="IconView_ContextMenuOpening" PreviewMouseMove="IconView_PreviewMouseMove"
                                 AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Foreground" Value="{DynamicResource TfxForeground}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource TfxSelection}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TfxSelectionForeground}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="108" Margin="6,7">
                                        <Image Source="{Binding LargeIcon}" Width="32" Height="32" HorizontalAlignment="Center" Stretch="None" SnapsToDevicePixels="True" />
                                        <TextBlock Text="{Binding Name}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Canvas x:Name="RightSelectionOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                            <Border x:Name="RightSelectionRect" BorderBrush="{DynamicResource TfxAccent}" BorderThickness="1" Background="{DynamicResource TfxSelectionOverlay}" />
                        </Canvas>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" Background="{DynamicResource TfxBorder}" HorizontalAlignment="Stretch" />

            <Border x:Name="PreviewHost" Grid.Column="4" Margin="0,8,8,8" Background="{DynamicResource TfxPanel}" BorderBrush="{DynamicResource TfxBorder}" BorderThickness="1">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="10,8,8,4">
                        <ToggleButton x:Name="RenderedToggle" DockPanel.Dock="Right" Style="{StaticResource ToolbarToggleButton}" Click="RenderedToggle_Click" Content="&#xE7B3;" Visibility="Collapsed" />
                        <Button x:Name="LoadImagesButton" DockPanel.Dock="Right" Style="{StaticResource ToolbarButton}" Click="LoadImages_Click"
                                Content="&#xE8B9;" Visibility="Collapsed" Margin="0,0,10,0" />
                        <TextBlock x:Name="PreviewHeader" Text="PREVIEW" Foreground="{DynamicResource TfxMuted}" VerticalAlignment="Center" />
                    </DockPanel>
                    <Grid>
                        <ScrollViewer x:Name="PreviewScroll">
                            <StackPanel Margin="10,0,10,10">
                                <TextBlock x:Name="InfoPreview" Foreground="{DynamicResource TfxForeground}" TextWrapping="Wrap" />
                                <Image x:Name="ImagePreview" Stretch="Uniform" Visibility="Collapsed" Margin="0,8,0,0"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBox x:Name="TextPreview" Background="{DynamicResource TfxInput}" Foreground="{DynamicResource TfxForeground}" BorderThickness="0" FontFamily="Consolas, Yu Gothic UI" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" Visibility="Collapsed" Margin="0,8,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                        <wv2:WebView2 x:Name="HtmlPreview" Visibility="Collapsed" />
                        <DataGrid x:Name="CsvPreview" Visibility="Collapsed" Background="{DynamicResource TfxInput}" Foreground="{DynamicResource TfxForeground}" BorderThickness="0"
                                  FontFamily="Consolas, Yu Gothic UI" GridLinesVisibility="None" HeadersVisibility="Column"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserReorderColumns="False" CanUserResizeColumns="True" CanUserSortColumns="True"
                                  RowBackground="{DynamicResource TfxInput}" AlternatingRowBackground="{DynamicResource TfxAlternatingRow}"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <GridSplitter x:Name="TerminalSplitter" Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" Background="{DynamicResource TfxBorder}"
                      Cursor="SizeNS" ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                      Visibility="Collapsed" />

        <Border x:Name="TerminalHost" Grid.Row="2" Visibility="Collapsed"
                Background="#0C0C0C" BorderBrush="{DynamicResource TfxBorder}" BorderThickness="0,1,0,0">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Background="{DynamicResource TfxChrome}" LastChildFill="True">
                    <Button x:Name="TerminalCloseButton" DockPanel.Dock="Right" Style="{StaticResource ToolbarButton}"
                            Click="TerminalClose_Click" Content="&#xE8BB;" Margin="0,2,4,2" />
                    <Button x:Name="TerminalInterruptButton" DockPanel.Dock="Left"
                            Click="TerminalInterrupt_Click"
                            Content="^C" FontFamily="Consolas, Yu Gothic UI" FontWeight="Bold"
                            Foreground="{DynamicResource TfxForeground}"
                            Background="{DynamicResource TfxInput}"
                            BorderBrush="{DynamicResource TfxBorder}"
                            BorderThickness="1" Padding="8,1" Margin="8,3,0,3" Cursor="Hand" />
                    <Button x:Name="TerminalQuitButton" DockPanel.Dock="Left"
                            Click="TerminalQuit_Click"
                            Content="^\" FontFamily="Consolas, Yu Gothic UI" FontWeight="Bold"
                            Foreground="{DynamicResource TfxForeground}"
                            Background="{DynamicResource TfxInput}"
                            BorderBrush="{DynamicResource TfxBorder}"
                            BorderThickness="1" Padding="8,1" Margin="4,3,0,3" Cursor="Hand" />
                    <Button x:Name="TerminalEofButton" DockPanel.Dock="Left"
                            Click="TerminalEof_Click"
                            Content="^Z" FontFamily="Consolas, Yu Gothic UI" FontWeight="Bold"
                            Foreground="{DynamicResource TfxForeground}"
                            Background="{DynamicResource TfxInput}"
                            BorderBrush="{DynamicResource TfxBorder}"
                            BorderThickness="1" Padding="8,1" Margin="4,3,0,3" Cursor="Hand" />
                    <TextBlock Text="TERMINAL" Foreground="{DynamicResource TfxMuted}" Margin="10,4" VerticalAlignment="Center" />
                </DockPanel>
                <Grid x:Name="TerminalContent">
                    <wv2:WebView2 x:Name="Terminal" DefaultBackgroundColor="Transparent"
                                  AllowExternalDrop="False" />
                    <!-- Shown only while a tfx drag is in progress. WebView2 is a
                         native child window and its HWND swallows OLE drop targeting,
                         so a same-HWND WPF element can't receive the drop. A Popup
                         has its OWN HWND, so it can sit over the WebView2 and accept
                         the drop. Sized to the WebView2 in ShowTerminalDropOverlay. -->
                    <Popup x:Name="TerminalDropOverlay" StaysOpen="True"
                           AllowsTransparency="True" Placement="Relative"
                           PlacementTarget="{Binding ElementName=Terminal}">
                        <Border x:Name="TerminalDropOverlayBorder" AllowDrop="True"
                                Background="#3007AACC" BorderBrush="#7DD3FC" BorderThickness="2"
                                DragOver="Terminal_DragOver" Drop="Terminal_FileDrop">
                            <TextBlock Text="Drop to paste path" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Consolas, Yu Gothic UI" FontSize="14" />
                        </Border>
                    </Popup>
                </Grid>
            </DockPanel>
        </Border>
        </Grid>
    </DockPanel>

    <!-- Window resize handles for the custom (chromeless) window: four edges +
         four corners. Corners are declared last so they win hit-testing where
         they overlap the edge strips. -->
    <Border Height="6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="8,0"
            Background="{DynamicResource TfxHitSurface}" Cursor="SizeNS"
            MouseLeftButtonDown="ResizeTop_MouseLeftButtonDown" />
    <Border Height="6" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="8,0"
            Background="{DynamicResource TfxHitSurface}" Cursor="SizeNS"
            MouseLeftButtonDown="ResizeBottom_MouseLeftButtonDown" />
    <Border Width="6" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="0,8"
            Background="{DynamicResource TfxHitSurface}" Cursor="SizeWE"
            MouseLeftButtonDown="ResizeLeft_MouseLeftButtonDown" />
    <Border Width="6" HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0,8"
            Background="{DynamicResource TfxHitSurface}" Cursor="SizeWE"
            MouseLeftButtonDown="ResizeRight_MouseLeftButtonDown" />

    <Border Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top"
            Background="{DynamicResource TfxHitSurface}" Cursor="SizeNWSE"
            MouseLeftButtonDown="ResizeTopLeft_MouseLeftButtonDown" />
    <Border Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top"
            Background="{DynamicResource TfxHitSurface}" Cursor="SizeNESW"
            MouseLeftButtonDown="ResizeTopRight_MouseLeftButtonDown" />
    <Border Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"
            Background="{DynamicResource TfxHitSurface}" Cursor="SizeNESW"
            MouseLeftButtonDown="ResizeBottomLeft_MouseLeftButtonDown" />
    <Border Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Background="{DynamicResource TfxHitSurface}" Cursor="SizeNWSE"
            MouseLeftButtonDown="ResizeBottomRight_MouseLeftButtonDown" />
    </Grid>
</Window>
