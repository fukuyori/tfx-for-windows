<Window x:Class="Tfx.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tfx"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="tfx"
        Icon="/Assets/AppIcon.ico"
        MinHeight="560"
        MinWidth="980"
        Height="760"
        Width="1280"
        Background="{StaticResource TfxBackground}"
        Foreground="{StaticResource TfxForeground}"
        FontFamily="Consolas, Yu Gothic UI"
        KeyDown="Window_KeyDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="ListingCellText" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <Style x:Key="RightAlignedCellText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#0B0E10" BorderBrush="{StaticResource TfxBorder}" BorderThickness="0,0,0,1" Padding="5,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BackButton" Style="{StaticResource ToolbarButton}" Click="Back_Click" ToolTip="Back (Ctrl+[)" Content="&#xE72B;" />
                    <Button x:Name="ForwardButton" Style="{StaticResource ToolbarButton}" Click="Forward_Click" ToolTip="Forward (Ctrl+])" Content="&#xE72A;" />
                    <Button x:Name="ParentButton" Style="{StaticResource ToolbarButton}" Click="Parent_Click" ToolTip="Up (Ctrl+Up / Backspace)" Content="&#xE74A;" />
                    <Button x:Name="OpenFolderButton" Style="{StaticResource ToolbarButton}" Click="OpenFolder_Click" ToolTip="Open folder" Content="&#xE838;" />
                    <Button x:Name="TogglePinButton" Style="{StaticResource ToolbarButton}" Click="TogglePin_Click" ToolTip="Pin / unpin current folder" Content="&#xE718;" />
                </StackPanel>
                <Grid Grid.Column="1" Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ActiveHeaderPathBorder" Background="#0D1013" BorderBrush="{StaticResource TfxBorder}" BorderThickness="1" MinHeight="22" Margin="0,0,8,0" Cursor="IBeam" ToolTip="Edit current path (Ctrl+L)" MouseLeftButtonDown="ActiveHeaderPath_MouseLeftButtonDown">
                        <TextBlock x:Name="ActiveHeaderPath" Foreground="{StaticResource TfxForeground}" FontFamily="Consolas, Yu Gothic UI" VerticalAlignment="Center" Padding="10,0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <TextBox x:Name="SearchBox" Grid.Column="1" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged" KeyDown="SearchBox_KeyDown" PreviewKeyDown="SearchBox_PreviewKeyDown" />
                    <Button x:Name="FocusSearchButton" Grid.Column="2" Style="{StaticResource ToolbarButton}" Click="FocusSearch_Click" ToolTip="Focus search (Ctrl+F)" Content="&#xE721;" />
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="ViewModeButton" Style="{StaticResource ToolbarButton}" Click="ViewMode_Click" ToolTip="Switch view mode" Content="&#xE8A9;" />
                    <ToggleButton x:Name="HiddenButton" Style="{StaticResource ToolbarToggleButton}" Click="Hidden_Click" ToolTip="Toggle hidden files (Ctrl+Shift+.)" Content="&#xE890;" />
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button x:Name="TerminalButton" Style="{StaticResource ToolbarButton}" Click="Terminal_Click" ToolTip="Open Terminal here (Ctrl+Shift+T)" Content="&#xE756;" />
                    <Button x:Name="ExplorerButton" Style="{StaticResource ToolbarButton}" Click="Explorer_Click" ToolTip="Reveal in Explorer" Content="&#xE838;" />
                    <Button x:Name="SelectAllButton" Style="{StaticResource ToolbarButton}" Click="SelectAll_Click" ToolTip="Select all (Ctrl+A)" Content="&#xE762;" />
                    <Button x:Name="ReloadButton" Style="{StaticResource ToolbarButton}" Click="Reload_Click" ToolTip="Reload (Ctrl+R)" Content="&#xE72C;" />
                    <ToggleButton x:Name="PreviewButton" Style="{StaticResource ToolbarToggleButton}" Click="Preview_Click" ToolTip="Toggle preview">
                        <Viewbox Width="15" Height="11" Stretch="Uniform">
                            <Grid Width="15" Height="11">
                                <Rectangle Width="14"
                                           Height="10"
                                           RadiusX="1.8"
                                           RadiusY="1.8"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                           StrokeThickness="1.4"
                                           Fill="Transparent"
                                           SnapsToDevicePixels="True" />
                                <Line X1="10"
                                      Y1="1.7"
                                      X2="10"
                                      Y2="9.3"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="1.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      SnapsToDevicePixels="True" />
                            </Grid>
                        </Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="SplitButton" Style="{StaticResource ToolbarToggleButton}" Click="Split_Click" ToolTip="Toggle split pane">
                        <Viewbox Width="15" Height="11" Stretch="Uniform">
                            <Grid Width="15" Height="11">
                                <Rectangle Width="14"
                                           Height="10"
                                           RadiusX="1.8"
                                           RadiusY="1.8"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                           StrokeThickness="1.4"
                                           Fill="Transparent"
                                           SnapsToDevicePixels="True" />
                                <Line X1="7.5"
                                      Y1="1.7"
                                      X2="7.5"
                                      Y2="9.3"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="1.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      SnapsToDevicePixels="True" />
                            </Grid>
                        </Viewbox>
                    </ToggleButton>
                    <Button x:Name="SwapPanesButton" Style="{StaticResource ToolbarButton}" Click="SwapPanes_Click" ToolTip="Swap left and right panes (Ctrl+Shift+S)">
                        <Viewbox Width="15" Height="11" Stretch="Uniform">
                            <Grid Width="15" Height="11">
                                <Rectangle Width="5"
                                           Height="9"
                                           RadiusX="1.2"
                                           RadiusY="1.2"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1.2"
                                           Fill="Transparent"
                                           SnapsToDevicePixels="True" />
                                <Rectangle Width="5"
                                           Height="9"
                                           RadiusX="1.2"
                                           RadiusY="1.2"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1.2"
                                           Fill="Transparent"
                                           SnapsToDevicePixels="True" />
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.1"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M 5.5,3.5 L 9.5,3.5 M 8.5,2.5 L 9.5,3.5 L 8.5,4.5 M 5.5,7.5 L 9.5,7.5 M 6.5,6.5 L 5.5,7.5 L 6.5,8.5"
                                      SnapsToDevicePixels="True" />
                            </Grid>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" x:Name="ColumnsButton" Click="Columns_Click" ToolTip="Columns" Content="&#xE713;" />
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="#0B0E10" Foreground="{StaticResource TfxMuted}" BorderBrush="{StaticResource TfxBorder}" BorderThickness="0,1,0,0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel HorizontalAlignment="Stretch" LastChildFill="False" />
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem DockPanel.Dock="Left">
                <TextBlock x:Name="StatusText" />
            </StatusBarItem>
            <StatusBarItem DockPanel.Dock="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="FreeSpaceText" Margin="0,0,12,0" />
                    <TextBlock x:Name="VersionStatusText" Margin="0,0,8,0" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="180" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition x:Name="PreviewSplitterColumn" Width="5" />
                <ColumnDefinition x:Name="PreviewColumn" Width="320" MinWidth="240" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource TfxPanel}" BorderBrush="{StaticResource TfxBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock x:Name="PinnedHeader" DockPanel.Dock="Top" Text="PINNED" Foreground="{StaticResource TfxMuted}" Margin="10,10,10,4" />
                    <ListBox x:Name="PinnedList" DockPanel.Dock="Top" Padding="0,0,0,12" Background="{StaticResource TfxPanel}" Foreground="{StaticResource TfxForeground}" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="PinnedList_SelectionChanged" PreviewMouseMove="PinnedList_PreviewMouseMove" PreviewMouseRightButtonDown="PinnedList_PreviewMouseRightButtonDown" ContextMenuOpening="PinnedList_ContextMenuOpening" DragOver="PinnedList_DragOver" Drop="PinnedList_Drop" AllowDrop="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <local:MiddleEllipsisTextBlock FullText="{Binding}"
                                                               ToolTip="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="FoldersHeader" DockPanel.Dock="Top" Text="FOLDERS" Foreground="{StaticResource TfxMuted}" Margin="10,4,10,4" />
                    <TreeView x:Name="FolderTree" Background="{StaticResource TfxPanel}" Foreground="{StaticResource TfxForeground}" BorderThickness="0" SelectedItemChanged="FolderTree_SelectedItemChanged" PreviewMouseLeftButtonUp="FolderTree_PreviewMouseLeftButtonUp" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="{StaticResource TfxBorder}" HorizontalAlignment="Stretch" />

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftPaneColumn" Width="*" />
                    <ColumnDefinition x:Name="PaneSplitterColumn" Width="5" />
                    <ColumnDefinition x:Name="RightPaneColumn" Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="LeftPaneBorder" Grid.Column="0" Background="{StaticResource TfxPanelActive}" BorderBrush="{StaticResource TfxBorder}" BorderThickness="1" Margin="8">
                    <DockPanel>
                        <local:PathBar x:Name="LeftPathBar" DockPanel.Dock="Top" Margin="6,6,6,4" PathRequested="LeftPathBar_PathRequested" />
                        <Grid>
                        <DataGrid x:Name="LeftGrid" ItemsSource="{Binding LeftItems}" IsReadOnly="True" MouseDoubleClick="Grid_MouseDoubleClick" SelectionChanged="Grid_SelectionChanged" GotFocus="Grid_GotFocus" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver" PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Listing_PreviewMouseLeftButtonUp" PreviewMouseMove="Grid_PreviewMouseMove" PreviewMouseRightButtonDown="Grid_PreviewMouseRightButtonDown" ContextMenuOpening="Grid_ContextMenuOpening" CellEditEnding="Grid_CellEditEnding" Sorting="Grid_Sorting" CanUserResizeColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn x:Name="LeftNameColumn" Header="Name" Width="280" MinWidth="200" SortMemberPath="Name" CanUserResize="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" SnapsToDevicePixels="True" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Name, Mode=OneWay}" VerticalAlignment="Center" Padding="6,2" FontFamily="Consolas, Yu Gothic UI" Loaded="RenameTextBox_Loaded" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="LeftDateModifiedColumn" Header="Date modified" Binding="{Binding ModifiedText}" SortMemberPath="Modified" Width="155" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftTypeColumn" Header="Type" Binding="{Binding Kind}" SortMemberPath="Kind" Width="110" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftSizeColumn" Header="Size" Binding="{Binding SizeText}" SortMemberPath="Size" Width="95" ElementStyle="{StaticResource RightAlignedCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftDateCreatedColumn" Header="Date created" Binding="{Binding CreatedText}" SortMemberPath="Created" Width="155" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftOwnerColumn" Header="Owner" Binding="{Binding OwnerText}" SortMemberPath="OwnerText" Width="160" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="LeftAttributeColumn" Header="Attribute" Binding="{Binding AttributeText}" SortMemberPath="AttributeText" Width="140" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <ListBox x:Name="LeftIconView" Visibility="Collapsed" ItemsSource="{Binding LeftItems}"
                                 Background="{StaticResource TfxPanel}" BorderThickness="0" SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="IconView_SelectionChanged" MouseDoubleClick="IconView_MouseDoubleClick"
                                 GotFocus="IconView_GotFocus" PreviewMouseLeftButtonDown="IconView_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Listing_PreviewMouseLeftButtonUp" PreviewMouseRightButtonDown="IconView_PreviewMouseRightButtonDown"
                                 ContextMenuOpening="IconView_ContextMenuOpening" PreviewMouseMove="IconView_PreviewMouseMove"
                                 AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Foreground" Value="{StaticResource TfxForeground}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#263845" />
                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="108" Margin="6,7">
                                        <Image Source="{Binding LargeIcon}" Width="32" Height="32" HorizontalAlignment="Center" Stretch="None" SnapsToDevicePixels="True" />
                                        <TextBlock Text="{Binding Name}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Canvas x:Name="LeftSelectionOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                            <Border x:Name="LeftSelectionRect" BorderBrush="{StaticResource TfxAccent}" BorderThickness="1" Background="#337DD3FC" />
                        </Canvas>
                        </Grid>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" Background="{StaticResource TfxBorder}" HorizontalAlignment="Stretch" />

                <Border x:Name="RightPaneBorder" Grid.Column="2" Background="{StaticResource TfxPanel}" BorderBrush="{StaticResource TfxBorder}" BorderThickness="1" Margin="8">
                    <DockPanel>
                        <local:PathBar x:Name="RightPathBar" DockPanel.Dock="Top" Margin="6,6,6,4" PathRequested="RightPathBar_PathRequested" />
                        <Grid>
                        <DataGrid x:Name="RightGrid" ItemsSource="{Binding RightItems}" IsReadOnly="True" MouseDoubleClick="Grid_MouseDoubleClick" SelectionChanged="Grid_SelectionChanged" GotFocus="Grid_GotFocus" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver" PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Listing_PreviewMouseLeftButtonUp" PreviewMouseMove="Grid_PreviewMouseMove" PreviewMouseRightButtonDown="Grid_PreviewMouseRightButtonDown" ContextMenuOpening="Grid_ContextMenuOpening" CellEditEnding="Grid_CellEditEnding" Sorting="Grid_Sorting" CanUserResizeColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn x:Name="RightNameColumn" Header="Name" Width="280" MinWidth="200" SortMemberPath="Name" CanUserResize="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" SnapsToDevicePixels="True" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Name, Mode=OneWay}" VerticalAlignment="Center" Padding="6,2" FontFamily="Consolas, Yu Gothic UI" Loaded="RenameTextBox_Loaded" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn x:Name="RightDateModifiedColumn" Header="Date modified" Binding="{Binding ModifiedText}" SortMemberPath="Modified" Width="155" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightTypeColumn" Header="Type" Binding="{Binding Kind}" SortMemberPath="Kind" Width="110" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightSizeColumn" Header="Size" Binding="{Binding SizeText}" SortMemberPath="Size" Width="95" ElementStyle="{StaticResource RightAlignedCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightDateCreatedColumn" Header="Date created" Binding="{Binding CreatedText}" SortMemberPath="Created" Width="155" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightOwnerColumn" Header="Owner" Binding="{Binding OwnerText}" SortMemberPath="OwnerText" Width="160" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                                <DataGridTextColumn x:Name="RightAttributeColumn" Header="Attribute" Binding="{Binding AttributeText}" SortMemberPath="AttributeText" Width="140" ElementStyle="{StaticResource ListingCellText}" CanUserResize="False" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <ListBox x:Name="RightIconView" Visibility="Collapsed" ItemsSource="{Binding RightItems}"
                                 Background="{StaticResource TfxPanel}" BorderThickness="0" SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="IconView_SelectionChanged" MouseDoubleClick="IconView_MouseDoubleClick"
                                 GotFocus="IconView_GotFocus" PreviewMouseLeftButtonDown="IconView_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Listing_PreviewMouseLeftButtonUp" PreviewMouseRightButtonDown="IconView_PreviewMouseRightButtonDown"
                                 ContextMenuOpening="IconView_ContextMenuOpening" PreviewMouseMove="IconView_PreviewMouseMove"
                                 AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Foreground" Value="{StaticResource TfxForeground}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#263845" />
                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="108" Margin="6,7">
                                        <Image Source="{Binding LargeIcon}" Width="32" Height="32" HorizontalAlignment="Center" Stretch="None" SnapsToDevicePixels="True" />
                                        <TextBlock Text="{Binding Name}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Canvas x:Name="RightSelectionOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                            <Border x:Name="RightSelectionRect" BorderBrush="{StaticResource TfxAccent}" BorderThickness="1" Background="#337DD3FC" />
                        </Canvas>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" Background="{StaticResource TfxBorder}" HorizontalAlignment="Stretch" />

            <Border x:Name="PreviewHost" Grid.Column="4" Margin="0,8,8,8" Background="{StaticResource TfxPanel}" BorderBrush="{StaticResource TfxBorder}" BorderThickness="1">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="10,8,8,4">
                        <ToggleButton x:Name="RenderedToggle" DockPanel.Dock="Right" Style="{StaticResource ToolbarToggleButton}" Click="RenderedToggle_Click" Content="&#xE7B3;" Visibility="Collapsed" />
                        <TextBlock x:Name="PreviewHeader" Text="PREVIEW" Foreground="{StaticResource TfxMuted}" VerticalAlignment="Center" />
                    </DockPanel>
                    <Grid>
                        <ScrollViewer x:Name="PreviewScroll">
                            <StackPanel Margin="10,0,10,10">
                                <TextBlock x:Name="InfoPreview" Foreground="{StaticResource TfxForeground}" TextWrapping="Wrap" />
                                <Image x:Name="ImagePreview" Stretch="Uniform" Visibility="Collapsed" Margin="0,8,0,0" />
                                <TextBox x:Name="TextPreview" Background="#0D1013" Foreground="{StaticResource TfxForeground}" BorderThickness="0" FontFamily="Consolas, Yu Gothic UI" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" Visibility="Collapsed" Margin="0,8,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                        <wv2:WebView2 x:Name="HtmlPreview" Visibility="Collapsed" />
                        <DataGrid x:Name="CsvPreview" Visibility="Collapsed" Background="#0D1013" Foreground="{StaticResource TfxForeground}" BorderThickness="0"
                                  FontFamily="Consolas, Yu Gothic UI" GridLinesVisibility="None" HeadersVisibility="Column"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserReorderColumns="False" CanUserResizeColumns="True" CanUserSortColumns="True"
                                  RowBackground="#0D1013" AlternatingRowBackground="#161A1E"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
