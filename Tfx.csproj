<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Version>0.1.0</Version>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <Authors>fukuyori</Authors>
    <Company>fukuyori</Company>
    <Product>tfx for Windows</Product>
    <Description>Terminal-inspired interface File eXplorer for Windows.</Description>
    <Copyright>Copyright 2026 fukuyori. Licensed under the Apache License, Version 2.0.</Copyright>
    <RepositoryUrl>https://github.com/fukuyori/tfx-for-windows</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/fukuyori/tfx-for-windows</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
  </PropertyGroup>

</Project>
