<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- Windows SDK projection unlocks Windows.Data.Pdf (PDFium-derived
         renderer shipped with the OS), used by PdfPreviewRenderer.Stage 2.
         SupportedOSPlatformVersion is held lower so the app still runs on
         Windows 10 1809 baseline. -->
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
    <Version>0.8.7</Version>
    <DefaultItemExcludes>$(DefaultItemExcludes);Tfx.Tests\**;Tfx.Core\**;artifacts\**</DefaultItemExcludes>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <Authors>fukuyori</Authors>
    <Company>fukuyori</Company>
    <Product>tfx for Windows</Product>
    <Description>Terminal-inspired interface File eXplorer for Windows.</Description>
    <Copyright>Copyright 2026 fukuyori. Licensed under the Apache License, Version 2.0.</Copyright>
    <RepositoryUrl>https://github.com/fukuyori/tfx-for-windows</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/fukuyori/tfx-for-windows</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\AppIcon.ico" />
  </ItemGroup>

  <ItemGroup>
    <!-- xterm.js terminal assets are embedded in the executable so the app runs
         as a single self-contained file. At startup they're written to a
         writable per-user folder and served to the WebView2-hosted terminal
         pane via a virtual host mapping (see MainWindow.Terminal.cs). -->
    <EmbeddedResource Include="Assets\terminal\**\*">
      <Link>TerminalAssets\%(Filename)%(Extension)</Link>
      <LogicalName>TfxTerminal.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Tfx.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Markdig" Version="0.37.0" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2592.51" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="Tfx.Core\Tfx.Core.csproj" />
  </ItemGroup>

</Project>
